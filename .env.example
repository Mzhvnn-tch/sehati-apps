# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/sehati_db

# Blockchain Configuration (Ethereum Sepolia & Polygon)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_MAINNET_RPC=https://polygon-rpc.com
CONTRACT_ADDRESS=
VITE_CONTRACT_ADDRESS=

# Admin Wallet Configuration (For Doctor Approvals)
ADMIN_WALLET=0xc771b3c8c495875df90f39467b9aeeac992f18fc
ADMIN_PRIVATE_KEY=your_admin_private_key_here

# Deployer Wallet (For Hardhat Deployment)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Test Doctor Wallet (for backend testing)
DOCTOR_WALLET=0x0D70fAff30ad1FeCbB2F3d20E20e1dfD50fFF30d
DOCTOR_PRIVATE_KEY=your_doctor_private_key_here

# Session Security
# Generate a secure string for this
SESSION_SECRET=change_this_to_a_random_secret_string

# Pinata IPFS Configuration
# Required for decentralized storage features
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here
VITE_PINATA_JWT=your_pinata_jwt_here
